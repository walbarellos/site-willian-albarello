# =========================================================
# personal-site - STAGING EXAMPLE
# Arquivo de exemplo seguro (sem segredos reais)
# =========================================================

# ---------------------------------------------------------
# Ambiente global
# ---------------------------------------------------------
NODE_ENV=production

# ---------------------------------------------------------
# API / Backend Fastify
# ---------------------------------------------------------
PORT=3002
SESSION_SECRET=__SET_STAGING_SESSION_SECRET_MIN_32_CHARS__
DATABASE_URL=__SET_STAGING_DATABASE_URL__

# URLs canônicas (staging)
PUBLIC_SITE_URL=https://staging-web.example.com
ADMIN_SITE_URL=https://staging-admin.example.com
CORS_ORIGINS=https://staging-web.example.com,https://staging-admin.example.com

# ---------------------------------------------------------
# Bootstrap administrativo
# Recomendado em staging para evitar ambiguidade operacional
# ---------------------------------------------------------
ADMIN_BOOTSTRAP_EMAIL=admin@staging.example.com
ADMIN_BOOTSTRAP_PASSWORD=__SET_STAGING_ADMIN_BOOTSTRAP_PASSWORD__
ADMIN_BOOTSTRAP_DISPLAY_NAME=Administrador Staging
ADMIN_BOOTSTRAP_ROLE=admin

# ---------------------------------------------------------
# Frontend público (apps/web)
# ---------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://staging-web.example.com

# API usada pelo frontend público (ordem de prioridade no código:
# NEXT_PUBLIC_API_URL -> PUBLIC_API_URL -> API_URL)
NEXT_PUBLIC_API_URL=https://staging-api.example.com
PUBLIC_API_URL=https://staging-api.example.com
API_URL=https://staging-api.example.com

# ---------------------------------------------------------
# Painel administrativo (apps/admin)
# ---------------------------------------------------------
NEXT_PUBLIC_ADMIN_URL=https://staging-admin.example.com

# API usada pelo painel admin (ordem de prioridade no código:
# NEXT_PUBLIC_API_URL -> ADMIN_API_URL -> API_URL)
ADMIN_API_URL=https://staging-api.example.com
