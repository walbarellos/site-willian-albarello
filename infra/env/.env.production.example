# =========================================================
# personal-site - PRODUCTION EXAMPLE
# Arquivo de exemplo seguro (sem segredos reais)
# =========================================================

# ---------------------------------------------------------
# Ambiente global
# ---------------------------------------------------------
NODE_ENV=production

# ---------------------------------------------------------
# API / Backend Fastify
# ---------------------------------------------------------
PORT=3002
SESSION_SECRET=__SET_PRODUCTION_SESSION_SECRET_MIN_32_CHARS__
DATABASE_URL=__SET_PRODUCTION_DATABASE_URL__

# URLs canônicas de produção
PUBLIC_SITE_URL=https://www.example.com
ADMIN_SITE_URL=https://admin.example.com
CORS_ORIGINS=https://www.example.com,https://admin.example.com

# ---------------------------------------------------------
# Bootstrap administrativo (obrigatório em produção)
# Fail-closed no backend se ausente
# ---------------------------------------------------------
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=__SET_PRODUCTION_ADMIN_BOOTSTRAP_PASSWORD__
ADMIN_BOOTSTRAP_DISPLAY_NAME=Administrador
ADMIN_BOOTSTRAP_ROLE=admin

# ---------------------------------------------------------
# Frontend público (apps/web)
# ---------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://www.example.com

# API usada pelo frontend público (ordem no código:
# NEXT_PUBLIC_API_URL -> PUBLIC_API_URL -> API_URL)
NEXT_PUBLIC_API_URL=https://api.example.com
PUBLIC_API_URL=https://api.example.com
API_URL=https://api.example.com

# ---------------------------------------------------------
# Painel administrativo (apps/admin)
# ---------------------------------------------------------
NEXT_PUBLIC_ADMIN_URL=https://admin.example.com

# API usada pelo painel admin (ordem no código:
# NEXT_PUBLIC_API_URL -> ADMIN_API_URL -> API_URL)
ADMIN_API_URL=https://api.example.com
