# =========================================================
# personal-site/.env.example
# Projeto William Albarello
# Contrato mínimo de ambiente para boot local do monorepo
# =========================================================
#
# Copie para ".env" na raiz do monorepo e ajuste conforme necessário.
# Em produção, use segredos reais e NÃO reutilize valores de desenvolvimento.
#

# ---------------------------------------------------------
# Ambiente global
# ---------------------------------------------------------
NODE_ENV=development

# ---------------------------------------------------------
# API / Backend Fastify
# ---------------------------------------------------------
PORT=3002
SESSION_SECRET=change-this-session-secret-with-at-least-32-characters
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/william_albarello

# URLs canônicas usadas pela API para CORS e referências cruzadas
PUBLIC_SITE_URL=http://localhost:3000
ADMIN_SITE_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ---------------------------------------------------------
# Bootstrap administrativo P0
# Fail-closed em produção: preencha obrigatoriamente
# ---------------------------------------------------------
ADMIN_BOOTSTRAP_EMAIL=admin@local.test
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe123!
ADMIN_BOOTSTRAP_DISPLAY_NAME=Administrador
ADMIN_BOOTSTRAP_ROLE=admin

# ---------------------------------------------------------
# Frontend público (apps/web)
# ---------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API usada pelo frontend público
NEXT_PUBLIC_API_URL=http://localhost:3002
PUBLIC_API_URL=http://localhost:3002
API_URL=http://localhost:3002

# ---------------------------------------------------------
# Painel administrativo (apps/admin)
# ---------------------------------------------------------
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# API usada pelo painel admin
ADMIN_API_URL=http://localhost:3002
